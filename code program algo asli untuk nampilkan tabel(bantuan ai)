def analisis_jumlah_klaster(data, k_min=2, k_max=10):
    """
    Menghitung visualisasi Elbow (Inertia) dan Silhouette Score
    menggunakan pustaka evaluasi eksternal dari Scikit-Learn.
    """
    list_inertia = []
    list_silhouette = []
    range_k = range(k_min, k_max + 1)

    for k in range_k:

        model_km = KMeans(n_clusters=k, tol=1e-4, max_iter=300, random_state=42, n_init=10)
        model_km.fit(data)

        list_inertia.append(model_km.inertia_)
        list_silhouette.append(silhouette_score(data, model_km.labels_))


    plt.figure(figsize=(12, 4))
    plt.subplot(1, 2, 1)
    plt.plot(range_k, list_inertia, marker='o', color='b')
    plt.title('Metode Elbow (Inertia)'); plt.xlabel('Nilai K'); plt.ylabel('Inertia'); plt.grid(True)

    plt.subplot(1, 2, 2)
    plt.plot(range_k, list_silhouette, marker='s', color='g')
    plt.title('Silhouette Score Standard'); plt.xlabel('Nilai K'); plt.ylabel('Skor'); plt.grid(True)
    plt.tight_layout(); plt.show()


