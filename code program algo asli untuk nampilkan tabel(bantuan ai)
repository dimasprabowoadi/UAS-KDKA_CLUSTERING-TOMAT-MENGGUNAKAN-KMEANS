  def bersihkan_background_library(img_hsv):
    """
    Membuat masker biner menggunakan fungsi bawaan OpenCV (cv2.inRange)
    untuk mengisolasi warna tomat (Merah, Oranye, Kuning, Hijau).
    """
    lower_red1, upper_red1 = np.array([0, 100, 50]), np.array([10, 255, 255])
    lower_red2, upper_red2 = np.array([160, 100, 50]), np.array([179, 255, 255])


    lower_green_yellow, upper_green_yellow = np.array([11, 50, 50]), np.array([85, 255, 255])


    mask_r1 = cv2.inRange(img_hsv, lower_red1, upper_red1)
    mask_r2 = cv2.inRange(img_hsv, lower_red2, upper_red2)
    mask_g = cv2.inRange(img_hsv, lower_green_yellow, upper_green_yellow)


    mask_tomat = cv2.bitwise_or(mask_r1, mask_r2)
    mask_tomat = cv2.bitwise_or(mask_tomat, mask_g)

    return mask_tomat

def ekstrak_fitur_dataset(image_folder, target_size=(100, 100)):
    """
    Membaca seluruh direktori gambar, menerapkan prapemrosesan citra,
    dan mengembalikan matriks fitur berdimensi [Jumlah_Gambar, 2].
    """
    features_list = []
    image_names = []

    if not os.path.exists(image_folder):
        print(f"Error: Folder '{image_folder}' tidak ditemukan.")
        return np.array([]), []

    valid_extensions = ('.jpg', '.jpeg', '.png', '.bmp', '.tiff')
    file_list = [f for f in os.listdir(image_folder) if f.lower().endswith(valid_extensions)]

    for filename in file_list:
        img_bgr = cv2.imread(os.path.join(image_folder, filename))
        if img_bgr is None:
            continue

    
        img_resized = cv2.resize(img_bgr, target_size)
        img_blur = cv2.GaussianBlur(img_resized, (5, 5), 0)
        img_hsv = cv2.cvtColor(img_blur, cv2.COLOR_BGR2HSV)

      
        mask = bersihkan_background_library(img_hsv)

        piksel_h = img_hsv[:, :, 0][mask > 0]
        piksel_s = img_hsv[:, :, 1][mask > 0]

      
        mean_h = np.mean(piksel_h) if len(piksel_h) > 0 else np.mean(img_hsv[:, :, 0])
        mean_s = np.mean(piksel_s) if len(piksel_s) > 0 else np.mean(img_hsv[:, :, 1])

        features_list.append([mean_h, mean_s])
        image_names.append(filename)

    return np.array(features_list), image_names


