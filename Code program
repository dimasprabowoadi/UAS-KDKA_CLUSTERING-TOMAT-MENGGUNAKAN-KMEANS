def jarak_euclid(a, b):
    return np.sqrt(np.sum((a - b)**2))

def jarak_manhattan(a, b):
    return np.sum(np.abs(a - b))

def jarak_minkowski(a, b, p=3):
    return np.sum(np.abs(a - b)**p)**(1/p)

def hitung_jarak_tunggal(a, b, jenis_jarak='euclidean'):
    if jenis_jarak == 'euclidean': return jarak_euclid(a, b)
    elif jenis_jarak == 'manhattan': return jarak_manhattan(a, b)
    elif jenis_jarak == 'minkowski': return jarak_minkowski(a, b, p=3)
