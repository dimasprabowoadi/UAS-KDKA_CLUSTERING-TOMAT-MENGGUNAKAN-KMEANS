def prediksi_gambar_baru(img_path):
    img_bgr = cv2.imread(img_path)
    if img_bgr is None: print(f"Gambar tidak ditemukan."); return
    img_hsv = cv2.cvtColor(cv2.GaussianBlur(cv2.resize(img_bgr, (100,100)), (5,5), 0), cv2.COLOR_BGR2HSV)
    mask = segmentasi_tomat(img_hsv)
    ph, ps = img_hsv[:,:,0][mask], img_hsv[:,:,1][mask]
    mh = np.mean(ph) if len(ph) > 0 else np.mean(img_hsv[:,:,0])
    ms = np.mean(ps) if len(ps) > 0 else np.mean(img_hsv[:,:,1])
    scaled = (np.array([mh, ms]) - data_min) / (data_max - data_min)

    print(f"predik gambar baru: {os.path.basename(img_path)}")
    for item in [{"n": "euclidean", "c": cnt_e}, {"n": "manhattan", "c": cnt_m}, {"n": "minkowski", "c": cnt_mk}]:
        jarak_k = [hitung_jarak_tunggal(scaled, cent, item["n"].lower().split()[0]) for cent in item["c"]]
        print(f" Jarak {item['n']:<10} - Masuk [Klaster {np.argmin(jarak_k)}] ")

