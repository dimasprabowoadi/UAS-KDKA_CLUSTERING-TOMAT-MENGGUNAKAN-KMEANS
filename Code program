def segmentasi_tomat(img_hsv):
    H, S = img_hsv[:,:,0], img_hsv[:,:,1]
    mask_merah1 = (H >= 0) & (H <= 10) & (S >= 100) & (S <= 255)
    mask_merah2 = (H >= 160) & (H <= 179) & (S >= 100) & (S <= 255)
    mask_hijau_kuning = (H >= 11) & (H <= 85) & (S >= 50) & (S <= 255)
    return mask_merah1 | mask_merah2 | mask_hijau_kuning

def preprocess_extract_background(image_folder, target_size=(100, 100)):
    features_list, image_names = [], []
    if not os.path.exists(image_folder): return np.array([]), []
    valid_extensions = ('.jpg', '.jpeg', '.png', '.bmp', '.tiff')
    file_list = [f for f in os.listdir(image_folder) if f.lower().endswith(valid_extensions)]

    for filename in file_list:
        img_bgr = cv2.imread(os.path.join(image_folder, filename))
        if img_bgr is None: continue
        img_hsv = cv2.cvtColor(cv2.GaussianBlur(cv2.resize(img_bgr, target_size), (5, 5), 0), cv2.COLOR_BGR2HSV)
        mask = segmentasi_tomat(img_hsv)
        piksel_h, piksel_s = img_hsv[:,:,0][mask], img_hsv[:,:,1][mask]
        mean_h = np.mean(piksel_h) if len(piksel_h) > 0 else np.mean(img_hsv[:,:,0])
        mean_s = np.mean(piksel_s) if len(piksel_s) > 0 else np.mean(img_hsv[:,:,1])
        features_list.append([mean_h, mean_s])
        image_names.append(filename)
    return np.array(features_list), image_names

