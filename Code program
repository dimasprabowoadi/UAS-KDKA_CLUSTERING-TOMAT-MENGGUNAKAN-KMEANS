def k_means(X, K, jenis_jarak='euclidean', max_iter=100, seed=42):
    np.random.seed(seed)
    centroids = X[np.random.choice(X.shape[0], K, replace=False)].copy()
    labels = np.zeros(X.shape[0])
    for _ in range(max_iter):
        jarak_matriks = np.zeros((X.shape[0], K))
        for i in range(X.shape[0]):
            for k in range(K): jarak_matriks[i, k] = hitung_jarak_tunggal(X[i], centroids[k], jenis_jarak)
        labels_baru = np.argmin(jarak_matriks, axis=1)
        if np.array_equal(labels, labels_baru): break
        labels = labels_baru
        for k in range(K):
            if len(X[labels == k]) > 0: centroids[k] = np.mean(X[labels == k], axis=0)
    return labels, centroids

